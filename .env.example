# Engram Configuration
# Copy to .env and fill in your values

# Embedder provider: "openai" (default) | "voyage"
# ENGRAM_EMBEDDER_PROVIDER=openai

# --- OpenAI / OpenRouter embedder ---
# Required when ENGRAM_EMBEDDER_PROVIDER=openai
ENGRAM_OPENAI_API_KEY=sk-...
# ENGRAM_OPENAI_BASE_URL=https://api.openai.com/v1
# ENGRAM_EMBEDDING_MODEL=text-embedding-3-small
# ENGRAM_EMBEDDING_DIMENSION=1536

# --- Voyage AI embedder ---
# Required when ENGRAM_EMBEDDER_PROVIDER=voyage
# ENGRAM_VOYAGE_API_KEY=pa-...
# ENGRAM_EMBEDDING_MODEL=voyage-3.5
# ENGRAM_EMBEDDING_DIMENSION=1024

# Optional: Qdrant settings (defaults shown)
# ENGRAM_QDRANT_URL=localhost:6334
# ENGRAM_COLLECTION_NAME=engram
# QDRANT_API_KEY=
