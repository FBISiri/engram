# Engram long-cycle reflection-heavy — example environment

# Collection that stores Aria's long-cycle memory.
ENGRAM_COLLECTION_NAME=siri_long_cycle

# Qdrant backing store (started in Step 1 of the README).
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_REST_PORT=6333

# Engram HTTP REST API — used by bootstrap.py (POST /memories).
ENGRAM_HOST=localhost
ENGRAM_HTTP_PORT=8080
# Optional: only needed if the Engram server is started with an API key.
# When set, bootstrap.py sends `Authorization: Bearer <key>`.
# ENGRAM_API_KEY=changeme

# Required for Reflection V2's Haiku calls (focal-question generation,
# evidence dialectic, insight synthesis). If unset, V2 silently degrades
# to V1 (flat reflection) — still functional, just less cross-domain depth.
ANTHROPIC_API_KEY=
