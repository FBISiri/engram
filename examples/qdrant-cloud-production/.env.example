# Engram — Qdrant Cloud Production Config
# Config 6: Production deployment with Qdrant Cloud, TLS, HTTP auth, and OpenTelemetry.
#
# Use this when:
#   - You're moving from local dev to a production environment
#   - Your Qdrant instance is hosted on Qdrant Cloud (or any TLS-secured remote Qdrant)
#   - You need HTTP + MCP transport simultaneously (scripts + AI agent)
#   - You want trace visibility via OpenTelemetry
#
# Copy to .env and fill in your values.

# ── Storage: Qdrant Cloud ──────────────────────────────────────────────────────
# Get your cluster URL from cloud.qdrant.io → Cluster → Connection Details
ENGRAM_QDRANT_URL=abc123.us-east4-0.gcp.cloud.qdrant.io:6334
ENGRAM_QDRANT_API_KEY=your-qdrant-cloud-api-key
ENGRAM_QDRANT_USE_TLS=true

# ── Embedding ──────────────────────────────────────────────────────────────────
# Recommended for production: voyage-3.5 (better quality, 1024-dim, lower cost)
# Switch to openai if you need OpenAI-only billing or have existing collections.
ENGRAM_EMBEDDER_PROVIDER=voyage
ENGRAM_VOYAGE_API_KEY=pa-your-voyage-key
ENGRAM_EMBEDDING_MODEL=voyage-3.5
ENGRAM_EMBEDDING_DIMENSION=1024

# Alternative: OpenAI text-embedding-3-large (3072-dim, higher cost)
# ENGRAM_EMBEDDER_PROVIDER=openai
# ENGRAM_OPENAI_API_KEY=sk-...
# ENGRAM_EMBEDDING_MODEL=text-embedding-3-large
# ENGRAM_EMBEDDING_DIMENSION=3072

# ── Transport: HTTP + MCP ──────────────────────────────────────────────────────
# "both" runs HTTP API (for dashboards/scripts) and MCP stdio (for AI agents)
# simultaneously. The binary decides per-connection based on whether stdin is a TTY.
ENGRAM_TRANSPORT=both
ENGRAM_HTTP_PORT=8080
# Required: protects the HTTP REST API. MCP (stdio) auth is handled by your MCP client.
ENGRAM_API_KEY=replace-with-a-long-random-secret

# ── Retrieval tuning ───────────────────────────────────────────────────────────
# Production defaults — typically no need to change unless you have specific
# recall vs. precision requirements (see docs/configuration.md §Scoring).
ENGRAM_WEIGHT_RELEVANCE=1.0
ENGRAM_WEIGHT_RECENCY=0.5
ENGRAM_WEIGHT_IMPORTANCE=0.3
ENGRAM_MMR_LAMBDA=0.5
ENGRAM_DEDUP_THRESHOLD=0.92

# ── Reflection Engine ──────────────────────────────────────────────────────────
# Enable for agents that should synthesize insights from accumulated memories.
ENGRAM_REFLECTION_ENABLED=true
ENGRAM_REFLECTION_TRIGGER=count
ENGRAM_REFLECTION_COUNT=15
# Use a capable model for production reflection quality.
ENGRAM_REFLECTION_MODEL=claude-sonnet-4-20250514
# Required by Reflection Engine (Anthropic API).
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ── Observability ──────────────────────────────────────────────────────────────
# Write traces to /var/log/engram/traces/ with 50% sampling (saves I/O in prod).
ENGRAM_OTEL_ENABLED=true
ENGRAM_OTEL_EXPORTER=file
ENGRAM_OTEL_FILE_DIR=/var/log/engram/traces
ENGRAM_OTEL_FILE_ROTATION=daily
# 1.0 = trace every op (dev), 0.1–0.5 = typical production sampling
ENGRAM_OTEL_SAMPLE_RATIO=0.5
