# Engram — Chatbot Session Memory Config
# Config 7: High-throughput chatbot with short-TTL session context.
#
# Use this when:
#   - Your chatbot serves many users and needs per-session context (not long-term memory)
#   - You want aggressive dedup (same user repeating context across sessions)
#   - Memories should expire automatically after days/weeks, not persist forever
#   - You're optimizing for low latency over rich recall
#
# Design philosophy:
#   - Recency-heavy scoring: recent context wins over historical facts
#   - High dedup threshold: tolerate near-duplicate session facts
#   - Reflection disabled: no synthesis overhead between user turns
#   - Lightweight embedding model: lower latency, adequate quality for chat
#
# Copy to .env and fill in your values.

# ── Storage ────────────────────────────────────────────────────────────────────
ENGRAM_QDRANT_URL=localhost:6334

# ── Embedding ──────────────────────────────────────────────────────────────────
# text-embedding-3-small: fastest + cheapest, good enough for session context.
# If retrieval quality matters more than latency, switch to voyage-3.5.
ENGRAM_EMBEDDER_PROVIDER=openai
ENGRAM_OPENAI_API_KEY=sk-...
ENGRAM_EMBEDDING_MODEL=text-embedding-3-small
ENGRAM_EMBEDDING_DIMENSION=1536

# ── Transport ──────────────────────────────────────────────────────────────────
# HTTP-only: your chatbot server calls Engram via REST API.
# No MCP needed unless an AI agent is co-located.
ENGRAM_TRANSPORT=http
ENGRAM_HTTP_PORT=8080
ENGRAM_API_KEY=replace-with-a-random-secret

# ── Scoring: recency-heavy, importance-light ───────────────────────────────────
# Recency dominates: users care what they said recently, not months ago.
# Low importance weight: chatbot context is uniformly low-importance.
# MMR lambda=0.7: favor relevance over diversity (session context is often repetitive).
ENGRAM_WEIGHT_RELEVANCE=1.0
ENGRAM_WEIGHT_RECENCY=1.2
ENGRAM_WEIGHT_IMPORTANCE=0.1
ENGRAM_MMR_LAMBDA=0.7

# ── Deduplication ─────────────────────────────────────────────────────────────
# Aggressive dedup (0.88): block near-paraphrases of the same session fact.
# Chatbots often receive repeated context ("I'm a vegetarian", "no meat please")
# across turns — dedup prevents bloating the collection with redundant entries.
ENGRAM_DEDUP_THRESHOLD=0.88

# ── Reflection Engine: disabled ────────────────────────────────────────────────
# Session-focused bots don't need insight synthesis between conversations.
# Re-enable if you add a long-term user profile layer on top of session memory.
ENGRAM_REFLECTION_ENABLED=false

# ── Observability ──────────────────────────────────────────────────────────────
# Low sampling ratio for high-throughput: trace 10% of ops to keep I/O minimal.
ENGRAM_OTEL_ENABLED=true
ENGRAM_OTEL_EXPORTER=file
ENGRAM_OTEL_FILE_DIR=/tmp/engram-traces
ENGRAM_OTEL_SAMPLE_RATIO=0.1
