# Engram Multi-Agent Shared Memory — Environment Variables
# Copy to .env and fill in your keys.

# Qdrant gRPC address (default: localhost:6334)
ENGRAM_QDRANT_URL=localhost:6334

# Embedding provider: openai (default) or voyage
ENGRAM_EMBEDDER_PROVIDER=openai

# OpenAI key (required when provider=openai)
ENGRAM_OPENAI_API_KEY=sk-...

# Voyage key (required when provider=voyage)
# ENGRAM_VOYAGE_API_KEY=pa-...

# Collection name — set per-agent at runtime, not here
# Siri: ENGRAM_COLLECTION_NAME=engram_user
# BMO:  ENGRAM_COLLECTION_NAME=bmo
# Shared team facts: ENGRAM_COLLECTION_NAME=team_shared
ENGRAM_COLLECTION_NAME=engram_user

# Engram REST API port (used by bootstrap.py)
ENGRAM_PORT=8080
