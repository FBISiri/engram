# Engram × Claude Code MCP Integration — Environment Variables
# Copy to .env and fill in your keys.

# ── Engram REST API (used by bootstrap.py for seeding) ────────────────────────
ENGRAM_HOST=localhost
ENGRAM_HTTP_PORT=8080

# ── Embedding provider ─────────────────────────────────────────────────────────
# Choose one: openai (default) or voyage
ENGRAM_EMBEDDER_PROVIDER=openai

# OpenAI key — required when ENGRAM_EMBEDDER_PROVIDER=openai
ENGRAM_OPENAI_API_KEY=sk-...

# Voyage key — required when ENGRAM_EMBEDDER_PROVIDER=voyage
# ENGRAM_VOYAGE_API_KEY=pa-...

# ── Collection ─────────────────────────────────────────────────────────────────
# One collection per project. Use a short, slug-friendly name.
ENGRAM_COLLECTION_NAME=my_project

# ── Qdrant (for bootstrap.py health check and Claude Code MCP config) ─────────
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334
QDRANT_REST_PORT=6333

# ── Optional: Reflection Engine (uncomment to enable weekly insight synthesis) ─
# ENGRAM_REFLECTION_ENABLED=true
# ENGRAM_REFLECTION_MODEL=claude-3-5-haiku-latest
# ANTHROPIC_API_KEY=sk-ant-...

# ── Path to engram binary (used when generating .mcp.json from template) ──────
# ENGRAM_BIN=/usr/local/bin/engram
